# Copy this file to .env and replace the placeholder values.
# On Vercel, set these as Environment Variables in the project settings.

# --- Supabase (client, exposed to browser) ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# --- Supabase (server, SSR / server functions) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Google Maps ---
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=your_google_maps_browser_api_key
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_TRACKING_ID=your_google_maps_tracking_id

# --- Demo Mode credentials (optional; server-side) ---
# Defaults are used if unset. Override in production if Demo Mode is enabled.
DEMO_ADMIN_PASSWORD=Admin@123
DEMO_DRIVER_PASSWORD=Driver@123
DEMO_FACULTY_PASSWORD=Faculty@123
DEMO_STUDENT_PASSWORD=Student@123