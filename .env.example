# Copy this file to .env and replace the placeholder values
# with your own Supabase and Google Maps credentials.
# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id

# Google Maps
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=your_google_maps_browser_api_key

# (Optional - if your project uses this)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_PROJECT_ID=your_supabase_project_id
